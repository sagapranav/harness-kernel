{
  "name": "@sagapranav/harness-kernel",
  "version": "0.1.0",
  "description": "Provider-neutral, append-only primitives for building durable agent harnesses.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./protocol": {
      "types": "./dist/src/protocol.d.ts",
      "import": "./dist/src/protocol.js"
    },
    "./journal": {
      "types": "./dist/src/journal.d.ts",
      "import": "./dist/src/journal.js"
    },
    "./artifacts": {
      "types": "./dist/src/artifacts.d.ts",
      "import": "./dist/src/artifacts.js"
    },
    "./conformance": {
      "types": "./dist/src/conformance.d.ts",
      "import": "./dist/src/conformance.js"
    },
    "./execution": {
      "types": "./dist/src/execution.d.ts",
      "import": "./dist/src/execution.js"
    },
    "./json": {
      "types": "./dist/src/json.d.ts",
      "import": "./dist/src/json.js"
    },
    "./projection": {
      "types": "./dist/src/projection.d.ts",
      "import": "./dist/src/projection.js"
    },
    "./providers": {
      "types": "./dist/src/providers.d.ts",
      "import": "./dist/src/providers.js"
    },
    "./runtime": {
      "types": "./dist/src/runtime.d.ts",
      "import": "./dist/src/runtime.js"
    },
    "./loop": {
      "types": "./dist/src/loop.d.ts",
      "import": "./dist/src/loop.js"
    },
    "./orchestration": {
      "types": "./dist/src/orchestration.d.ts",
      "import": "./dist/src/orchestration.js"
    },
    "./sessions": {
      "types": "./dist/src/sessions.d.ts",
      "import": "./dist/src/sessions.js"
    },
    "./storage": {
      "types": "./dist/src/storage.d.ts",
      "import": "./dist/src/storage.js"
    },
    "./telemetry": {
      "types": "./dist/src/telemetry.d.ts",
      "import": "./dist/src/telemetry.js"
    },
    "./work": {
      "types": "./dist/src/work.d.ts",
      "import": "./dist/src/work.js"
    },
    "./node": {
      "types": "./dist/src/node.d.ts",
      "import": "./dist/src/node.js"
    }
  },
  "files": [
    "src",
    "dist/src",
    "dist/examples",
    "docs",
    "examples",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm test && npm run format:check",
    "pack:check": "npm pack --dry-run --cache .npm-cache",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagapranav/harness-kernel.git"
  },
  "keywords": [
    "agents",
    "ai",
    "event-log",
    "harness",
    "llm",
    "openai",
    "anthropic",
    "tool-use"
  ]
}
